# URL of the Python face-search API (Render service).
# Leave unset for local single-machine dev (the built-in /api/search route runs
# python3 directly). On Vercel, set this to your Render service URL so the
# browser calls the backend directly:
#   NEXT_PUBLIC_API_URL=https://kumbh-milaap-api.onrender.com
NEXT_PUBLIC_API_URL=
